generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  status    String   @default("ok")
  createdAt DateTime @default(now())
}

enum Role {
  ORG_ADMIN
  RECRUITER
  CANDIDATE
  VIEWER
}

model Tenant {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  dpdpConsentAt        DateTime?
  encryptedAnthropicKey String?
  webhookSecret        String
  creditsBalance       Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  memberships          Membership[]
  auditLogs            AuditLog[]
  mockEmails           MockEmail[]
  questions            Question[]
  questionnaireTemplates QuestionnaireTemplate[]
  candidates           Candidate[]
  candidateQuestionnaires CandidateQuestionnaire[]
  referees             Referee[]
  refereeResponses     RefereeResponse[]

  @@index([slug])
}

enum QuestionCategory {
  WORK_STYLE
  COLLABORATION
  IMPACT
  LEADERSHIP
  INTEGRITY
  OTHER
}

model Question {
  id          String           @id @default(cuid())
  tenantId    String
  text        String
  helpText    String?
  category    QuestionCategory
  isArchived  Boolean          @default(false)
  createdBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateItems QuestionnaireTemplateItem[]

  @@index([tenantId])
  @@index([category])
  @@index([isArchived])
}

model QuestionnaireTemplate {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  roleCategory  String
  description   String?
  isArchived    Boolean  @default(false)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  QuestionnaireTemplateItem[]

  @@index([tenantId])
  @@index([isArchived])
}

model QuestionnaireTemplateItem {
  id         String   @id @default(cuid())
  templateId String
  questionId String
  order      Int      @default(0)

  template Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionnaireTemplate QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, questionId])
  @@index([templateId])
  @@index([questionId])
}

enum CandidateStatus {
  ACTIVE
  ARCHIVED
  DELETED_DPDP
}

model Candidate {
  id              String          @id @default(cuid())
  tenantId        String
  createdByUserId String
  firstName       String
  lastName        String
  email           String
  phone           String?
  roleTitle       String
  notes           String?
  status          CandidateStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User                     @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  questionnaire   CandidateQuestionnaire[]
  referees        Referee[]

  @@index([tenantId])
  @@index([status])
  @@index([email])
}

model CandidateQuestionnaire {
  id              String   @id @default(cuid())
  candidateId     String   @unique
  tenantId        String
  frozenAt        DateTime @default(now())
  templateSnapshot  Json

  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([candidateId])
}

enum RefereeStatus {
  INVITED
  REMINDED
  SUBMITTED
  REVOKED
}

model Referee {
  id              String        @id @default(cuid())
  tenantId        String
  candidateId     String
  name            String
  email           String
  relationship    String
  inviteToken     String        @unique
  invitedAt       DateTime      @default(now())
  remindedAt      DateTime?
  lastReminderAt  DateTime?
  submittedAt     DateTime?
  status          RefereeStatus @default(INVITED)

  candidate       Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responses       RefereeResponse[]

  @@index([tenantId])
  @@index([candidateId])
  @@index([inviteToken])
  @@index([status])
}

model RefereeResponse {
  id                  String   @id @default(cuid())
  refereeId           String
  tenantId            String
  questionId          String
  questionTextSnapshot String
  answerText          String
  submittedAt         DateTime @default(now())

  referee             Referee  @relation(fields: [refereeId], references: [id], onDelete: Cascade)
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([refereeId])
  @@index([questionId])
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String?
  emailVerified  DateTime?
  image          String?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  memberships  Membership[]
  auditLogs    AuditLog[] @relation("ActorAuditLogs")
  candidates   Candidate[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  actorUserId  String?
  action       String
  targetType   String
  targetId     String?
  metadata     Json?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([actorUserId])
  @@index([targetType, targetId])
}

model MockEmail {
  id        String   @id @default(cuid())
  to        String
  subject   String
  html      String?
  text      String?
  category  String
  tenantId  String?
  sentAt    DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}
